# wactl — Environment Configuration
# Copy this file to .env and fill in the values

# === Required ===
MCP_API_KEY=           # API key for MCP endpoint authentication (generate with: openssl rand -hex 32)
ADMIN_PASSWORD_HASH=   # bcrypt hash of admin password (generate with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 12))")

# === Server Ports ===
ADMIN_PORT=8080        # Web admin panel port
MCP_PORT=3000          # MCP SSE server port
BRIDGE_PORT=4000       # Internal Go bridge port (localhost only)
CALLBACK_PORT=4001     # Internal bridge callback port (localhost only)

# === Admin ===
ADMIN_USER=admin       # Admin panel username

# === Notifications ===
NOTIFY_METHOD=none     # "ntfy" or "none"
NTFY_TOPIC=            # ntfy.sh topic name (required if NOTIFY_METHOD=ntfy)
SERVER_IP=             # Public IP/hostname for notification click URLs (auto-detected if empty)

# === Auto-Update ===
AUTO_UPDATE=true       # Enable automatic whatsmeow update checks
AUTO_UPDATE_CRON=0 3 * * *  # Cron schedule for update checks

# === Data ===
DATA_DIR=./data        # Path to SQLite + session data directory
BRIDGE_DIR=./bridge    # Path to Go bridge source (for auto-updater)
